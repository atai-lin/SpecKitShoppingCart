<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SpecKit Shopping</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">
    <header class="bg-white shadow-sm">
        <nav class="container mx-auto px-4 py-4 flex justify-between items-center">
            <a class="text-xl font-bold text-blue-600" asp-page="/Index">SpecKit Shopping</a>
            <div class="flex space-x-6 items-center">
                <a class="text-gray-600 hover:text-blue-600" asp-page="/Products/Index">Shop</a>
                <a class="text-gray-600 hover:text-blue-600" asp-page="/Privacy">Privacy</a>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow container mx-auto px-4 py-8">
        @RenderBody()
    </main>

    <footer class="bg-white border-t border-gray-200 py-6 mt-12">
        <div class="container mx-auto px-4 text-center text-gray-500">
            &copy; 2026 - SpecKit Shopping - <a asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
