@page "{id:int}"
@model ShoppingCart.Pages.Products.DetailModel
@{
    ViewData["Title"] = Model.Product!.Name;
}

<div class="bg-atelier-bg min-h-screen">
    <div class="max-w-[1440px] mx-auto px-8 py-24">
        <div class="mb-12">
            <a asp-page="/Products/Index" class="text-[12px] uppercase tracking-[1.2px] text-atelier-dark hover:text-atelier-green transition-colors font-work flex items-center gap-2 group">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="transition-transform group-hover:-translate-x-1">
                    <path d="M19 12H5M5 12L12 19M5 12L12 5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>Back to Essentials</span>
            </a>
        </div>

        <div class="flex flex-col lg:flex-row gap-16 lg:gap-24 items-start">
            <!-- Image Section -->
            <div class="w-full lg:w-3/5">
                <div class="bg-atelier-footer aspect-[4/5] overflow-hidden">
                    @if (!string.IsNullOrEmpty(Model.Product!.ImageUrl))
                    {
                        <img src="@Model.Product!.ImageUrl" alt="@Model.Product!.Name" class="w-full h-full object-cover">
                    }
                    else
                    {
                        <div class="w-full h-full flex flex-col items-center justify-center text-atelier-gray/30">
                            <svg class="w-24 h-24 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            <span class="text-[12px] uppercase tracking-wider">No visual available</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Info Section -->
            <div class="w-full lg:w-2/5 space-y-12">
                <div class="space-y-4">
                    <span class="text-[12px] uppercase tracking-[1.2px] text-atelier-gray font-work">@Model.Product!.CategoryName</span>
                    <h1 class="text-[48px] lg:text-[64px] leading-tight font-extrabold text-atelier-dark uppercase tracking-[-1.92px] font-manrope">@Model.Product!.Name</h1>
                    <div class="flex items-baseline gap-4">
                        <span class="text-[32px] font-bold text-atelier-dark font-manrope">$@Model.Product!.Price.ToString("#,##0")</span>
                        <span class="text-[12px] uppercase tracking-[1.2px] text-atelier-green font-work">Limited Availability</span>
                    </div>
                </div>

                <div class="pt-12 border-t border-atelier-border space-y-8">
                    <div class="space-y-4">
                        <h3 class="text-[12px] font-bold uppercase tracking-[1.2px] text-atelier-dark font-manrope">The Detail</h3>
                        <p class="text-[16px] text-atelier-gray leading-relaxed font-work">
                            @Model.Product!.Description
                        </p>
                    </div>

                    <div class="grid grid-cols-2 gap-8 py-8 border-t border-b border-atelier-divider">
                        <div>
                            <div class="text-[10px] text-atelier-gray uppercase tracking-[1px] font-work mb-1">Material</div>
                            <div class="text-[14px] font-medium text-atelier-dark uppercase font-work">@Model.Product!.Material</div>
                        </div>
                        <div>
                            <div class="text-[10px] text-atelier-gray uppercase tracking-[1px] font-work mb-1">Color</div>
                            <div class="flex items-center gap-2">
                                <div class="w-3 h-3 rounded-full border border-atelier-border" style="background-color: @Model.Product!.Color"></div>
                                <div class="text-[14px] font-medium text-atelier-dark uppercase font-work">@Model.Product!.Color</div>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-4">
                        <button class="w-full bg-atelier-green text-[#ebfcea] px-8 py-5 text-[14px] uppercase tracking-[2.4px] font-medium hover:bg-atelier-dark transition-all duration-500 font-work">
                            Add to Wardrobe
                        </button>
                        <button class="w-full border border-atelier-dark text-atelier-dark px-8 py-5 text-[14px] uppercase tracking-[2.4px] font-medium hover:bg-atelier-dark hover:text-white transition-all duration-500 font-work">
                            Add to Wishlist
                        </button>
                    </div>

                    <div class="text-[11px] text-atelier-gray italic font-work text-center">
                        Our pieces are crafted through an architectural approach to wardrobe building, ensuring substance over trend.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
