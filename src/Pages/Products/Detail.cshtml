@page "{id:int}"
@model ShoppingCart.Pages.Products.DetailModel
@{
    ViewData["Title"] = Model.Product!.Name;
}

<div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
    <div class="md:flex">
        <!-- Image Section -->
        <div class="md:w-1/2 bg-gray-100 flex items-center justify-center p-8">
            @if (!string.IsNullOrEmpty(Model.Product!.ImageUrl))
            {
                <img src="@Model.Product!.ImageUrl" alt="@Model.Product!.Name" class="max-w-full h-auto rounded-lg shadow-md">
            }
            else
            {
                <div class="text-gray-400 flex flex-col items-center">
                    <svg class="w-24 h-24 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    <span>No Image Available</span>
                </div>
            }
        </div>

        <!-- Info Section -->
        <div class="md:w-1/2 p-8 md:p-12">
            <div class="text-sm font-medium text-blue-600 mb-2 uppercase tracking-wider">@Model.Product!.CategoryName</div>
            <h1 class="text-3xl font-bold text-gray-900 mb-4">@Model.Product!.Name</h1>
            
            <div class="flex items-center space-x-4 mb-8">
                <span class="text-3xl font-bold text-gray-900">$@Model.Product!.Price.ToString("F2")</span>
                <span class="bg-green-100 text-green-800 text-xs font-semibold px-2.5 py-0.5 rounded">In Stock</span>
            </div>

            <div class="border-t border-b border-gray-100 py-6 mb-8">
                <h3 class="text-sm font-medium text-gray-900 mb-2">Description</h3>
                <p class="text-gray-600 leading-relaxed">
                    @Model.Product!.Description
                </p>
            </div>

            <div class="grid grid-cols-2 gap-4 mb-8">
                <div class="bg-gray-50 p-3 rounded-md">
                    <div class="text-xs text-gray-500 uppercase">Sales Volume</div>
                    <div class="font-semibold">@Model.Product!.SalesVolume</div>
                </div>
                <div class="bg-gray-50 p-3 rounded-md">
                    <div class="text-xs text-gray-500 uppercase">Listed Date</div>
                    <div class="font-semibold">@Model.Product!.CreatedTime.ToString("yyyy-MM-dd")</div>
                </div>
            </div>

            <div class="flex space-x-4">
                <button class="flex-grow bg-blue-600 text-white px-6 py-3 rounded-md font-bold hover:bg-blue-700 transition">Add to Cart</button>
                <button class="p-3 border border-gray-300 rounded-md text-gray-400 hover:text-red-500 hover:border-red-500 transition">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"></path></svg>
                </button>
            </div>

            <div class="mt-8 text-sm text-gray-500 italic">
                Free shipping on orders over $1000.
            </div>
        </div>
    </div>
</div>

<div class="mt-8">
    <a asp-page="/Products/Index" class="text-blue-600 hover:text-blue-800 font-medium flex items-center space-x-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        <span>Back to Product List</span>
    </a>
</div>
